{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "surface-knowledge-record",
  "title": "Surface knowledge record",
  "description": "Durable, accumulating, two-sided (old/new) record of a surface's components and their data sources. The record is a Markdown file: this structured object is carried in its YAML **front-matter** (the leading `---` block), and the prose body below it holds the human-readable narrative (per-component `whatItDoes`/`behavior`) \u2014 those narrative fields are optional in the front-matter and not machine-validated. The record describes a surface; it does not carry a worklist \u2014 what a story should build comes from its epic's seeds. Built by gather-surface-knowledge.md; consumed by write-story / plan / implement / QA. features/ is hand-curated and never written here. Legacy raw `.json` records still validate for back-compat.",
  "type": "object",
  "required": [
    "surface"
  ],
  "additionalProperties": true,
  "properties": {
    "surface": {
      "type": "string",
      "minLength": 1,
      "description": "<area>/<surface-key>"
    },
    "route": {
      "type": "string"
    },
    "sourceRefs": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "features": {
          "type": "string"
        },
        "legacy": {
          "type": "string"
        },
        "openapi": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "newCode": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "old": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/component"
      }
    },
    "new": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/component"
      }
    },
    "openGaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "what"
        ],
        "additionalProperties": true,
        "properties": {
          "what": {
            "type": "string"
          },
          "prerequisite": {
            "type": "string"
          }
        }
      }
    },
    "journeys": {
      "type": "array",
      "description": "Documented typical user journeys for this surface, read from the repo's feature docs. Each becomes a journey-level acceptance criterion the writer must include.",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string"
          },
          "surface": {
            "type": "string"
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "sourcesRead": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "iteration": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  },
  "$defs": {
    "dataSource": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "api",
            "computed",
            "static",
            "legacy"
          ]
        },
        "endpoint": {
          "type": "string"
        },
        "field": {
          "type": "string"
        },
        "template": {
          "type": "string"
        }
      }
    },
    "component": {
      "type": "object",
      "required": [
        "name"
      ],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string"
        },
        "whatItDoes": {
          "type": "string"
        },
        "behavior": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "interaction": {
              "type": "string"
            },
            "options": {
              "type": "string"
            },
            "async": {
              "type": "string"
            },
            "states": {
              "type": "string"
            }
          }
        },
        "dataSource": {
          "$ref": "#/$defs/dataSource"
        },
        "entryPoint": {
          "type": "string"
        },
        "chromeContext": {
          "type": "object",
          "additionalProperties": true,
          "description": "Context-conditional chrome: where this component is present vs. absent.",
          "properties": {
            "presentOn": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "absentOn": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "feedbackKind": {
          "type": "string",
          "enum": [
            "transient",
            "steady"
          ]
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ostler/knowledge-record.schema.json",
  "title": "Knowledge Concept frontmatter (docs/knowledge/**/*.md)",
  "type": "object",
  "required": ["type", "surface"],
  "additionalProperties": true,
  "properties": {
    "type": { "const": "knowledge" },
    "surface": { "type": "string", "minLength": 1 },
    "route": { "type": ["string", "null"] },
    "sourceRefs": { "type": "object", "additionalProperties": true },
    "old": { "type": "array" },
    "new": { "type": "array" },
    "gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "component": { "type": "string" },
          "oldState": { "type": "string" },
          "newState": { "type": "string" },
          "kind": { "type": "string" },
          "disposition": { "type": "string" },
          "owner": { "type": "string" }
        }
      }
    },
    "openGaps": { "type": "array" },
    "journeys": { "type": "array" },
    "provenance": { "type": "object", "additionalProperties": true }
  }
}

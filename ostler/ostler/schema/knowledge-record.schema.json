{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ostler/knowledge-record.schema.json",
  "title": "Knowledge Concept frontmatter (docs/knowledge/**/*.md)",
  "type": "object",
  "required": ["type", "surface"],
  "additionalProperties": true,
  "properties": {
    "type": { "const": "knowledge" },
    "surface": { "type": "string", "minLength": 1 },
    "route": { "type": ["string", "null"] },
    "sourceRefs": { "type": "object", "additionalProperties": true },
    "old": { "type": "array" },
    "new": { "type": "array" },
    "openGaps": { "type": "array" },
    "journeys": { "type": "array" },
    "provenance": { "type": "object", "additionalProperties": true }
  }
}

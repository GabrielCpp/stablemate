# With a workhorse run-level profile that declares a managed `proxy:` (see
# workhorse-profiles.yaml), you do NOT need a .env at all: workhorse generates the
# proxy's auth token itself (persisted at ~/.config/workhorse/proxy-secret), starts
# the proxy on the profile's port, and injects the token + base URL into the CLI.
#
# The ONLY thing that must be in your environment is the real upstream key below —
# and that is typically already exported by your shell (~/.bashrc). This file is
# only for running `docker compose -f compose.litellm.yaml up` BY HAND (without
# workhorse), where compose needs the vars itself.

# Your OpenRouter API key (https://openrouter.ai/keys). Starts with sk-or-v1-...
# workhorse passes this through to the proxy from the ambient environment.
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Only needed for a MANUAL `docker compose up` (workhorse supplies these itself):
#   LITELLM_MASTER_KEY  — the proxy's auth token (any random string)
#   LITELLM_PORT        — host port (default 4000; use 4444 — :4000 is the Firebase
#                         Emulator Suite UI)
# LITELLM_MASTER_KEY=sk-local-REPLACE_ME
# LITELLM_PORT=4444

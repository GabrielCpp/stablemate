# Copy to `.env` and fill in. `.env` is gitignored — never commit your key.

# Your OpenRouter API key (https://openrouter.ai/keys). Starts with sk-or-v1-...
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Any random string — the local proxy's auth token. The agent CLI sends this as
# its API key; OpenRouter never sees it. e.g. `openssl rand -hex 16`
LITELLM_MASTER_KEY=sk-local-REPLACE_ME

# Where the proxy listens (used by run-workflow.sh). Default is fine.
LITELLM_BASE_URL=http://localhost:4000

# Which agent CLI to drive: codex | copilot | claude. codex is the default
# (verified ~99% cached prefix). For codex, run ./setup-codex-profile.sh once.
AGENT_CLI=codex

# Logical model name (must match a model_name in litellm-config.yaml).
AGENT_MODEL=mimo
